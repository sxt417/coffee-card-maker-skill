{
  "version": "2.0.0",
  "system_name": "Flavor Semantic Color Field",
  "highest_principle": "不要把每个风味画成一个颜色光斑，而是把所有风味组织成一个完整的感官色彩场。主风味决定画面的主色和最大面积，次要风味以衰减的方式融入其中；不同风味类别通过柔软、模糊、局部化的抽象形态进行暗示，最终形成连续、面性、柔和且具有编辑设计感的渐变构图。",
  "default_flavor_weights": [0.42, 0.25, 0.16, 0.10, 0.07],
  "shape_languages": {
